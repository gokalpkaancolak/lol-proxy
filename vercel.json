{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://cbaiddia.xyz/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/riot",
      "destination": "/api/riot"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
