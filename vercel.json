{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "lol-proxy-chi.vercel.app" }],
      "destination": "https://cbaiddia.xyz/:1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/riot", "destination": "/api/riot" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
